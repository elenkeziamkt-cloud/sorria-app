{
  "expo": {
    "name": "SorrIA",
    "slug": "sorria-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "porto-rio",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gamboaacao.sorria"
    },
    "android": {
      "package": "com.gamboaacao.sorria",
      "adaptiveIcon": {
        "backgroundColor": "#C4BDB5",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        { "enableFTS": true }
      ],
      "expo-asset",
      "expo-status-bar",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
